---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import homepageData from '../data/homepage.json';
import clientesData from '../data/clientes.json';
import servicosData from '../data/servicos.json';

const posts = (await getCollection('noticias'))
  .sort((a, b) => b.data.data.getTime() - a.data.data.getTime())
  .slice(0, 3);

const { hero_label, hero_titulo_1, hero_titulo_2, hero_subtitulo, hero_cta_primario, hero_cta_secundario, stats, diferenciais_titulo, diferenciais, cta_titulo, cta_subtitulo, cta_botao_primario, cta_botao_secundario } = homepageData;
const clientes = clientesData.clientes.slice(0, 10);
const servicos = servicosData.lista.slice(0, 6);

// Adinkra-inspired icons — formas derivadas do elemento visual Akoma Ntoaso
const ak: Record<string, string> = {
  // Quadrado com meia-lua côncava no canto superior esquerdo
  qtl:     `<path d="M12,0 L24,0 L24,24 L0,24 L0,12 A12,12 0 0,0 12,0 Z"/>`,
  // Círculo cheio
  circle:  `<circle cx="12" cy="12" r="10"/>`,
  // Semicírculo cúpula (plano abaixo, curva para cima)
  dome:    `<path d="M2,12 A10,10 0 0,0 22,12 Z"/>`,
  // D-shape (plano à esquerda, curva para direita)
  dright:  `<path d="M12,2 A10,10 0 0,1 12,22 Z"/>`,
  // Quadrado com meia-lua côncava no canto inferior direito
  qbr:     `<path d="M0,0 L24,0 L24,12 A12,12 0 0,0 12,24 L0,24 Z"/>`,
  // Semicírculo tigela (plano acima, curva para baixo)
  bowl:    `<path d="M2,12 A10,10 0 0,1 22,12 Z"/>`,
  // Flor Akoma: 4 pétalas semicirculares + ponto central
  akoma:   `<path d="M7,12 A5,5 0 0,0 17,12 Z M12,7 A5,5 0 0,1 12,17 Z M7,12 A5,5 0 0,1 17,12 Z M12,7 A5,5 0 0,0 12,17 Z"/><circle cx="12" cy="12" r="2.2"/>`,
};
---

<Layout
  title="Marketing Digital Ético e Estratégico"
  description="Imagini é a agência de marketing digital que humaniza marcas e respeita pessoas. Marketing com alma, estratégia e verdade."
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="section-label">{hero_label}</div>
          <h1 class="display">
            {hero_titulo_1}<br />
            <em>{hero_titulo_2}</em>
          </h1>
          <p class="hero-sub">{hero_subtitulo}</p>
          <div class="hero-actions">
            <a href="/contato" class="btn btn-primary">{hero_cta_primario}</a>
            <a href="/sobre" class="btn btn-ghost">{hero_cta_secundario}</a>
          </div>
          <div class="hero-stats">
            {stats.map((s, i) => (
              <>
                {i > 0 && <div class="stat-divider"></div>}
                <div class="stat">
                  <span class="stat-num">{s.numero}</span>
                  <span class="stat-label">{s.label}</span>
                </div>
              </>
            ))}
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <!-- Akoma Ntoaso — brand element in 3 nested scales -->
          <svg class="hero-geo" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer petals r=240 — partial arcs at viewport edges -->
            <path d="M -20,180 A 240,240 0 0,0 460,180" stroke="#881726" stroke-width="1.5" opacity="0.07" stroke-linecap="round"/>
            <path d="M 220,-60 A 240,240 0 0,1 220,420" stroke="#881726" stroke-width="1"   opacity="0.06" stroke-linecap="round"/>
            <!-- Middle petals r=160 — full cross visible in viewport -->
            <path d="M 60,180 A 160,160 0 0,0 380,180"  stroke="#881726" stroke-width="1.5" opacity="0.11" stroke-linecap="round"/>
            <path d="M 60,180 A 160,160 0 0,1 380,180"  stroke="#881726" stroke-width="1"   opacity="0.07" stroke-linecap="round"/>
            <path d="M 220,20 A 160,160 0 0,0 220,340"  stroke="#881726" stroke-width="1"   opacity="0.09" stroke-linecap="round"/>
            <path d="M 220,20 A 160,160 0 0,1 220,340"  stroke="#881726" stroke-width="1"   opacity="0.06" stroke-linecap="round"/>
            <!-- Inner petals r=90 -->
            <path d="M 130,180 A 90,90 0 0,0 310,180"  stroke="#881726" stroke-width="1"   opacity="0.09" stroke-linecap="round"/>
            <path d="M 220,90  A 90,90 0 0,1 220,270"  stroke="#881726" stroke-width="1"   opacity="0.08" stroke-linecap="round"/>
            <!-- Amber accent — diagonal sweep -->
            <path d="M 60,380 A 260,260 0 0,1 380,60" stroke="#f8b967" stroke-width="2" opacity="0.30" stroke-linecap="round"/>
            <!-- Small Akoma flower — brand mark -->
            <g transform="translate(374,54)" fill="#881726" opacity="0.48">
              <path d="M -9,0 A 9,9 0 0,0 9,0 Z"/>
              <path d="M 0,-9 A 9,9 0 0,1 0,9 Z"/>
              <path d="M -9,0 A 9,9 0 0,1 9,0 Z"/>
              <path d="M 0,-9 A 9,9 0 0,0 0,9 Z"/>
              <circle cx="0" cy="0" r="2.5"/>
            </g>
            <!-- Dot grid — Adinkra brand pattern -->
            <g fill="#881726" opacity="0.16">
              {[0,1,2,3,4].map(col => [0,1,2,3,4,5].map(row =>
                <circle cx={50 + col*28} cy={182 + row*28} r="2.3"/>
              ))}
            </g>
          </svg>

          <div class="hero-card hero-card-1">
            <div class="hc-dot">
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
                <path d="M2,12 A10,10 0 0,0 22,12 Z"/>
              </svg>
            </div>
            <p>Marcas que crescem com alma</p>
          </div>
          <div class="hero-card hero-card-2">
            <div class="hc-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" set:html={ak.akoma}/>
            </div>
            <p>Parceiros de evolução genuína</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MANIFESTO STRIP -->
  <section class="manifesto-strip">
    <div class="container">
      <p>
        {[
          'Ideias que ganham forma.',
          'Crescimento com alma.',
          'Estrutura com propósito.',
          'Conhecimento como legado.',
        ].map(text => (
          <span>
            <svg class="manifesto-icon" viewBox="0 0 24 24" fill="currentColor" width="11" height="11" aria-hidden="true" set:html={ak.akoma}/>
            {text}
          </span>
        ))}
      </p>
    </div>
  </section>

  <!-- POR QUE A IMAGINI -->
  <section class="alt">
    <div class="container">
      <div class="section-label">Nosso diferencial</div>
      <h2 class="h2" style="max-width:600px; margin-bottom:56px;">{diferenciais_titulo}</h2>

      <div class="diff-grid">
        {diferenciais.map((d, i) => (
          <div class="diff-item">
            <div class="diff-num">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="h3">{d.titulo}</h3>
            <p>{d.descricao}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section>
    <div class="container">
      <div class="section-label">O que fazemos</div>
      <div class="services-header">
        <h2 class="h2">Serviços pensados<br />para o seu negócio real</h2>
        <a href="/servicos" class="btn btn-outline">Ver todos os serviços</a>
      </div>

      <div class="grid-3">
        {servicos.map(s => (
          <div class="card service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" width="30" height="30" set:html={ak[s.icone] ?? ak.circle}/>
            </div>
            <h3 class="h3">{s.nome}</h3>
            <p>{s.descricao}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLIENTES / PORTFÓLIO TEASER -->
  <section class="alt">
    <div class="container">
      <div class="section-label">Portfólio</div>
      <div class="portfolio-header">
        <h2 class="h2">Parcerias que<br />fazem a diferença</h2>
        <a href="/portfolio" class="btn btn-outline">Ver portfólio completo</a>
      </div>
      <div class="clients-logos">
        {clientes.map(c => (
          <a href="/portfolio" class="cl-item">
            <img src={c.logo} alt={c.nome} loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NOTÍCIAS -->
  {posts.length > 0 && (
    <section>
      <div class="container">
        <div class="section-label">Notícias e artigos</div>
        <div class="news-header">
          <h2 class="h2">Conteúdo que<br />gera conhecimento</h2>
          <a href="/noticias" class="btn btn-outline">Ver todos</a>
        </div>
        <div class="grid-3">
          {posts.map(post => (
            <a href={`/noticias/${post.slug}`} class="card news-card">
              {post.data.categoria && <span class="tag">{post.data.categoria}</span>}
              <h3 class="h3">{post.data.titulo}</h3>
              <p class="news-excerpt">{post.data.resumo}</p>
              <span class="news-date">{post.data.data.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA FINAL -->
  <section class="dark cta-section">
    <div class="container" style="position:relative; overflow:hidden;">
      <!-- Akoma Ntoaso — decoração geométrica da marca -->
      <svg class="cta-geo" viewBox="0 0 500 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Outer petals r=250, center (420,200) -->
        <path d="M 170,200 A 250,250 0 0,0 670,200" stroke="white" stroke-width="1" opacity="0.05" stroke-linecap="round"/>
        <path d="M 420,-50 A 250,250 0 0,1 420,450" stroke="white" stroke-width="1" opacity="0.04" stroke-linecap="round"/>
        <!-- Middle petals r=165, center (420,200) -->
        <path d="M 255,200 A 165,165 0 0,0 585,200" stroke="white" stroke-width="1" opacity="0.07" stroke-linecap="round"/>
        <path d="M 255,200 A 165,165 0 0,1 585,200" stroke="white" stroke-width="1" opacity="0.05" stroke-linecap="round"/>
        <path d="M 420,35  A 165,165 0 0,0 420,365" stroke="white" stroke-width="1" opacity="0.06" stroke-linecap="round"/>
        <path d="M 420,35  A 165,165 0 0,1 420,365" stroke="white" stroke-width="1" opacity="0.04" stroke-linecap="round"/>
        <!-- Inner petals r=90, center (420,200) -->
        <path d="M 330,200 A 90,90 0 0,0 510,200" stroke="white" stroke-width="1" opacity="0.07" stroke-linecap="round"/>
        <path d="M 420,110 A 90,90 0 0,1 420,290" stroke="white" stroke-width="1" opacity="0.06" stroke-linecap="round"/>
        <!-- Amber accent arc -->
        <path d="M 0,380 A 340,340 0 0,1 420,20" stroke="#f8b967" stroke-width="1.5" opacity="0.18" stroke-linecap="round"/>
        <!-- Dot grid -->
        <g fill="white" opacity="0.07">
          {[0,1,2,3].map(col => [0,1,2,3,4].map(row =>
            <circle cx={32 + col*32} cy={40 + row*32} r="3"/>
          ))}
        </g>
      </svg>

      <div class="cta-inner">
        <div class="section-label">Vamos começar</div>
        <h2 class="h2" style="color:white;">{cta_titulo}</h2>
        <p>{cta_subtitulo}</p>
        <div class="cta-actions">
          <a href="/contato" class="btn btn-accent">{cta_botao_primario}</a>
          <a href="/servicos" class="btn btn-outline-white">{cta_botao_secundario}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero { padding: 96px 0 80px; overflow: hidden; }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 80px;
    align-items: center;
  }
  .hero h1 { margin: 16px 0 24px; }
  .hero h1 em { font-style: normal; color: var(--primary); }
  .hero-sub {
    font-size: 18px;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 36px;
  }
  .hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }

  .hero-stats { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .stat-num { font-family: var(--font-display); font-size: 28px; font-weight: 800; color: var(--primary); }
  .stat-label { font-size: 12px; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-divider { width: 1px; height: 40px; background: var(--border); }

  /* Hero visual */
  .hero-visual {
    position: relative;
    height: 420px;
  }
  .hero-geo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-card {
    position: absolute;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    box-shadow: var(--shadow-md);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
    max-width: 240px;
    z-index: 2;
  }
  .hero-card-1 { top: 40px; left: 20px; }
  .hero-card-2 { bottom: 60px; right: 0; }
  .hc-dot { color: var(--accent); margin-bottom: 10px; display: flex; }
  .hc-icon { color: var(--primary); margin-bottom: 10px; display: flex; }

  /* MANIFESTO STRIP */
  .manifesto-strip {
    background: var(--primary);
    padding: 24px 0;
  }
  .manifesto-strip p {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: white;
  }
  .manifesto-strip span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 20px;
  }
  .manifesto-icon { color: var(--accent); flex-shrink: 0; }

  /* DIFERENCIAL */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .diff-item {
    padding: 40px 32px;
    background: white;
    transition: background 0.2s;
  }
  .diff-item:hover { background: var(--primary-light); }
  .diff-num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 900;
    color: var(--accent);
    opacity: 0.6;
    line-height: 1;
    margin-bottom: 20px;
  }
  .diff-item h3 { margin-bottom: 12px; }
  .diff-item p { font-size: 15px; color: var(--text-muted); line-height: 1.6; }

  /* SERVICES */
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .service-card { gap: 0; }
  .service-icon {
    color: var(--accent);
    margin-bottom: 20px;
    line-height: 1;
    display: flex;
  }
  .service-card h3 { margin-bottom: 12px; }
  .service-card p { font-size: 15px; color: var(--text-muted); line-height: 1.65; }

  /* PORTFOLIO */
  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .clients-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .cl-item {
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 14px 20px;
    height: 72px;
    transition: all 0.22s;
  }
  .cl-item:hover {
    border-color: var(--primary-mid);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }
  .cl-item img {
    max-height: 40px;
    max-width: 110px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.65);
    transition: filter 0.22s;
  }
  .cl-item:hover img { filter: grayscale(0%) opacity(1); }

  /* NEWS */
  .news-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .news-card { display: flex; flex-direction: column; gap: 12px; text-decoration: none; }
  .news-card:hover h3 { color: var(--primary); }
  .news-excerpt { font-size: 15px; color: var(--text-muted); line-height: 1.6; flex: 1; }
  .news-date { font-size: 13px; color: var(--text-light); margin-top: auto; }

  /* CTA */
  .cta-section { padding: 96px 0; }
  .cta-inner { max-width: 720px; position: relative; z-index: 1; }
  .cta-geo {
    position: absolute;
    right: -40px;
    top: 50%;
    transform: translateY(-50%);
    width: 500px;
    height: 400px;
    pointer-events: none;
  }
  .cta-section .section-label { color: var(--accent); }
  .cta-section .section-label::before { background: var(--accent); }
  .cta-section p { font-size: 18px; color: rgba(255,255,255,0.6); margin: 24px 0 40px; }
  .cta-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .diff-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .hero { padding: 64px 0 48px; }
    .hero-sub { font-size: 16px; }
    .hero-actions { flex-direction: column; align-items: stretch; gap: 12px; }
    .hero-actions .btn { justify-content: center; text-align: center; }
    .hero-stats { gap: 16px; }
    .stat-num { font-size: 22px; }
    .stat-divider { display: none; }
    .diff-grid { grid-template-columns: 1fr; }
    .diff-item { padding: 28px 24px; }
    .manifesto-strip p { flex-direction: column; text-align: center; }
    .manifesto-strip span::before { display: none; }
    .services-header, .portfolio-header, .news-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-actions { flex-direction: column; align-items: stretch; }
    .cta-actions .btn { justify-content: center; text-align: center; }
  }
</style>
